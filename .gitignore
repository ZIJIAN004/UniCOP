# Monorepo 级 .gitignore（兜底两个子项目）
# 子项目有自己的 .gitignore,此文件处理跨项目通用的排除项

# ── Python ─────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
env/
*.egg

# ── 训练产物 ───────────────────────────────────────
model/
output*/
eval_results*/
checkpoints/
merged_model/
*.bin
*.safetensors
*.pt
*.pth
*.pkl
*.ckpt

# ── 数据集 (大文件) ────────────────────────────────
data/
*.jsonl
*.npz

# ── 日志 ───────────────────────────────────────────
logs/
*.log
wandb/
runs/

# ── IDE / 编辑器 ───────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── OS 垃圾 ────────────────────────────────────────
$RECYCLE.BIN/
Desktop.ini

# ── 临时 ───────────────────────────────────────────
*.tmp
*.bak
*.orig

# ── 本机同步脚本 (含凭据,不上库) ──────────────────
sync_to_server.sh

# ── 空/测试文本 ────────────────────────────────────
新建 文本文档.txt
"新建 文本文档.txt"
